# Pipeline-regenerated outputs (see clean_outputs.ps1 / clean_outputs.sh).
# If these paths were ever committed, stop tracking once with:
#   git rm -r --cached data/filtered data/resampled data/cycle_points_original data/cycle_points_resampled results/plots results/calibration
# (keeps files on disk; after commit, only .gitignore applies to new files.)
data/filtered/
data/resampled/
data/cycle_points_original/
data/cycle_points_resampled/
results/plots/
results/calibration/

# Summary tables / rollups (report scripts + generalized optimize).
summary_statistics/

# config/test eval outputs (run_eval_params_metrics.py, etc.)
config/test/overlays/
config/test/simulated_force/
config/test/params_eval_metrics.csv

# Full pipeline zip snapshots (archive_pipeline_outputs.ps1 / .sh)
run_snapshots/
